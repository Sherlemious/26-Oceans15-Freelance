<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <springProperty scope="context" name="serviceName" source="spring.application.name" defaultValue="user-service"/>
    <springProperty scope="context" name="lokiUrl" source="LOKI_URL" defaultValue="http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push"/>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{ISO8601} %-5level [%thread] [%X{correlationId:-}] [%X{userId:-}] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}</url>
            <useProtobufApi>false</useProtobufApi>
        </http>
        <batch>
            <timeoutMs>1000</timeoutMs>
        </batch>
        <labels>
            app=freelance
            service=${serviceName}
            level=%level
            env=k8s
        </labels>
        <structuredMetadata>off</structuredMetadata>
        <message class="com.team26.freelance.user.logging.UserServiceJsonLogLayout"/>
    </appender>

    <springProfile name="k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>

    <springProfile name="!k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>
</configuration>
