            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "payouts",
            "{{pendingPayoutId}}",
            "promos",
            "{{activePromoCodeId}}"
          ]
        },
        "description": "Payout is PENDING, promo code is active, not expired, has available uses, and not already applied."
      }
    },
