# Copy this file to .env and fill in real values.

SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

SPRING_DATA_MONGODB_URI=mongodb://root:rootpass@mongo:27017/freelancemongo?authSource=admin

SPRING_DATA_REDIS_PASSWORD=redispass

JWT_SECRET=REPLACE_WITH_SHARED_BASE64_SECRET
JWT_EXPIRATION=86400000

CACHE_TTL_DASHBOARD=600
CACHE_TTL_SEARCH=300
CACHE_TTL_ACTIVITY=300
CACHE_TTL_DETAIL=900
