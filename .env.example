# Copy this file to .env and fill in real values.

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/freelancedb
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=postgres

# MongoDB
SPRING_DATA_MONGODB_URI=mongodb://root:rootpass@mongo:27017/freelancemongo?authSource=admin

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=redispass

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4j

# JWT
JWT_SECRET=REPLACE_WITH_SHARED_BASE64_SECRET
JWT_EXPIRATION=86400000

# Cache TTLs (seconds)
CACHE_TTL_DASHBOARD=600
CACHE_TTL_SEARCH=300
CACHE_TTL_ACTIVITY=300
CACHE_TTL_DETAIL=900
