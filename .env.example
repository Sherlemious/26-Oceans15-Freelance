# Copy this file to .env and fill in real values before running any service.
# Never commit .env to version control.

# PostgreSQL
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/freelancedb
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# MongoDB (include credentials in the URI)
SPRING_DATA_MONGODB_URI=

# Redis
SPRING_REDIS_HOST=localhost
SPRING_REDIS_PORT=6379
SPRING_REDIS_PASSWORD=

# Neo4j (proposal-service)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=
NEO4J_PASSWORD=

# JWT (shared across all services — use a long random base64 string)
JWT_SECRET=
JWT_EXPIRATION=86400000

# Cache TTLs in seconds
CACHE_TTL_DASHBOARD=600
CACHE_TTL_SEARCH=300
CACHE_TTL_ACTIVITY=300
CACHE_TTL_DETAIL=900
