<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <springProperty scope="context" name="appName" source="spring.application.name" defaultValue="job-service"/>
    <springProperty scope="context" name="lokiUrl" source="loki.url" defaultValue="http://loki.monitoring.svc.cluster.local:3100/loki/api/v1/push"/>

    <appender name="LOKI" class="com.github.loki4j.logback.Loki4jAppender">
        <http>
            <url>${lokiUrl}</url>
        </http>
        <labels>
            app=freelance
            service=${appName}
            level=%level
            env=k8s
        </labels>
        <structuredMetadata>off</structuredMetadata>
        <message class="com.team26.freelance.job.logging.JobServiceJsonLogLayout"/>
    </appender>

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <springProfile name="k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="LOKI"/>
        </root>
    </springProfile>
    <springProfile name="!k8s">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
        </root>
    </springProfile>

    <logger name="com.team26.freelance.job.feign" level="DEBUG"/>
    <logger name="org.springframework.cloud.openfeign" level="DEBUG"/>
    <logger name="feign" level="DEBUG"/>

</configuration>
